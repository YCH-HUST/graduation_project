<view class="page-container" wx:if="{{!isLoading && !error}}">

  <!-- 状态栏 -->
  <view class="detail-header">
    <view>
      <text class="case-id-text">病例 #{{caseData.id}}</text>
      <text class="case-time-text">{{caseData.timeText}}</text>
    </view>
    <view class="badge {{statusBgClass}}">{{statusText}}</view>
  </view>

  <!-- 处理中提示 -->
  <view class="card processing-card" wx:if="{{caseData.status === 'running' || caseData.status === 'created'}}">
    <text class="processing-icon">⚙️</text>
    <text class="processing-title">正在处理中</text>
    <text class="processing-desc">系统正在分析您的舌象数据，请稍候...</text>
    <view class="progress-wrap" style="margin-top:20rpx" wx:if="{{run}}">
      <view class="progress-bar" style="width:{{run.progress}}%"></view>
    </view>
  </view>

  <!-- ========== 医生确认结果(主要) ========== -->
  <block wx:if="{{doctorResult}}">

    <!-- 医生信息标题行 -->
    <view class="doctor-result-header">
      <text class="doctor-result-icon">🩺</text>
      <view class="doctor-result-info">
        <text class="doctor-result-title">医生诊疗结果</text>
        <text class="doctor-result-sub">{{doctorResult.doctorName}} · 已{{doctorResult.decision === 'revise' ? '修订' : '审核通过'}}</text>
      </view>
    </view>

    <!-- 确认的证候 -->
    <view class="card">
      <text class="card-title">🏥 确认证候</text>
      <view class="tag-grid">
        <view class="tag tag-syndrome tag-confirmed" wx:for="{{doctorResult.syndromes}}" wx:key="name">
          <text>{{item.name}}</text>
          <text wx:if="{{item.description}}" class="tag-sub">{{item.description}}</text>
        </view>
      </view>
    </view>

    <!-- 处方用药 -->
    <view class="card">
      <text class="card-title">💊 处方用药</text>
      <view class="tag-grid">
        <view class="tag tag-formula tag-confirmed" wx:for="{{doctorResult.herbs}}" wx:key="name">
          <text>{{item.name}}</text>
        </view>
      </view>
    </view>

    <!-- 医嘱备注 -->
    <view class="card" wx:if="{{doctorResult.note}}">
      <text class="card-title">📋 医嘱</text>
      <view class="note-box">
        <text class="note-text">{{doctorResult.note}}</text>
      </view>
    </view>

  </block>

  <!-- ========== AI 分析结果 (有医生结论时作参考，无时作主要) ========== -->
  <block wx:if="{{result}}">

    <view class="section-divider" wx:if="{{doctorResult}}">
      <text class="divider-text">以下为 AI 辅助分析（仅供参考）</text>
    </view>

    <!-- 证候分析 -->
    <view class="card {{doctorResult ? 'card-reference' : ''}}">
      <view class="card-title-row">
        <text class="card-title">🩺 {{doctorResult ? 'AI 证候参考' : '证候分析'}}</text>
      </view>
      <view class="tag-grid">
        <view class="tag tag-syndrome" wx:for="{{result.syndromes}}" wx:key="name">
          <text>{{item.name}}</text>
          <text wx:if="{{item.description}}" class="tag-sub">{{item.description}}</text>
        </view>
      </view>
    </view>

    <!-- 推荐用药 -->
    <view class="card {{doctorResult ? 'card-reference' : ''}}">
      <text class="card-title">💊 {{doctorResult ? 'AI 推荐用药参考' : '推荐用药'}}</text>
      <view class="tag-grid">
        <view class="tag tag-formula" wx:for="{{result.formulas}}" wx:key="name">
          <text>{{item.name}}</text>
        </view>
      </view>
    </view>

    <!-- 证据要点 -->
    <view class="card {{doctorResult ? 'card-reference' : ''}}">
      <text class="card-title">📝 证据要点</text>
      <view class="evidence-item" wx:for="{{result.evidence_points}}" wx:key="index">
        <view class="evidence-num">{{index + 1}}</view>
        <text class="evidence-text">{{item}}</text>
      </view>
    </view>

    <!-- AI 综合分析（可折叠） -->
    <view class="card {{doctorResult ? 'card-reference' : ''}}">
      <view class="toggle-header" bindtap="toggleExplanation">
        <text class="card-title">🤖 AI 综合分析</text>
        <text class="toggle-arrow">{{showExplanation ? '▲' : '▼'}}</text>
      </view>
      <view wx:if="{{showExplanation}}" class="explanation-text">
        <text>{{result.llm_explanation}}</text>
      </view>
    </view>

  </block>

  <!-- 可视化图片 -->
  <view class="card" wx:if="{{assets.length > 0}}">
    <text class="card-title">🖼 可视化资源</text>
    <view class="assets-grid">
      <view
        class="asset-item"
        wx:for="{{assets}}"
        wx:key="id"
        bindtap="onPreviewImage"
        data-url="{{item.fullUrl}}"
      >
        <image src="{{item.fullUrl}}" class="asset-img" mode="aspectFill" lazy-load />
        <text class="asset-label">{{item.typeName}}</text>
      </view>
    </view>
  </view>

  <!-- 问诊信息 -->
  <view class="card">
    <text class="card-title">📋 问诊信息</text>
    <view class="q-item" wx:for="{{caseData.qEntries}}" wx:key="label">
      <text class="q-label">{{item.label}}</text>
      <text class="q-value">{{item.value || '-'}}</text>
    </view>
  </view>

</view>

<!-- 加载中 -->
<view class="loading-wrap full-loading" wx:if="{{isLoading}}">
  <text style="font-size:72rpx">⏳</text>
  <text class="loading-text">加载中...</text>
</view>

<!-- 错误 -->
<view class="loading-wrap full-loading" wx:if="{{error}}">
  <text style="font-size:72rpx">❌</text>
  <text class="loading-text">{{error}}</text>
  <button class="btn-primary" style="width:240rpx;margin-top:32rpx" bindtap="onReload">重新加载</button>
</view>
