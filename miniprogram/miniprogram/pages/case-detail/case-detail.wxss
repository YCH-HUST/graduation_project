/* pages/case-detail/case-detail.wxss */
.full-loading { height: 80vh; }

.detail-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 24rpx;
}
.case-id-text { display: block; font-size: 32rpx; font-weight: 700; color: #0f172a; }
.case-time-text { display: block; font-size: 22rpx; color: #94a3b8; margin-top: 4rpx; }

/* 处理中 */
.processing-card { text-align: center; }
.processing-icon { display: block; font-size: 72rpx; margin-bottom: 16rpx; }
.processing-title { display: block; font-size: 32rpx; font-weight: 700; color: #0f172a; }
.processing-desc { display: block; font-size: 26rpx; color: #94a3b8; margin-top: 8rpx; }

/* AI 诊断完成，等待患者确认提交 */
.submit-confirm-card { text-align: center; background: linear-gradient(135deg, #f0fdf4, #dcfce7); border: 2rpx solid #86efac; }
.submit-confirm-icon { display: block; font-size: 72rpx; margin-bottom: 16rpx; }
.submit-confirm-title { display: block; font-size: 32rpx; font-weight: 700; color: #166534; }
.submit-confirm-desc { display: block; font-size: 26rpx; color: #4ade80; margin-top: 8rpx; color: #16a34a; }
.btn-submit-doctor {
  margin-top: 32rpx;
  background: linear-gradient(135deg, #10b981, #059669);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 48rpx;
  height: 88rpx;
  line-height: normal;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.4);
}
.btn-submit-doctor::after { border: none; }


.card-title-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20rpx; }
.conf-text { font-size: 24rpx; color: #10b981; font-weight: 600; }

/* 标签网格（证候 / 方剂） */
.tag-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 8rpx;
}
.tag {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 14rpx 28rpx;
  border-radius: 48rpx;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.4;
}
.tag-syndrome {
  background: #d1fae5;
  color: #fbbf24;
}

.chat-float-btn {
  position: fixed;
  right: 40rpx;
  bottom: 80rpx;
  background-color: #10b981;
  color: #fff;
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  box-shadow: 0 8rpx 20rpx rgba(16, 185, 129, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
  z-index: 100;
}

.tag-formula {
  background: #cffafe;
  color: #164e63;
}
.tag-sub {
  display: block;
  font-size: 20rpx;
  font-weight: 400;
  opacity: 0.75;
  margin-top: 4rpx;
}


/* 方剂 */
.formula-item {
  background: #f8fafc; border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx;
}
.formula-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12rpx; }
.formula-name { font-size: 28rpx; font-weight: 700; color: #0f172a; }
.formula-row { display: flex; margin-bottom: 8rpx; }
.formula-label { font-size: 24rpx; color: #64748b; font-weight: 600; flex-shrink: 0; width: 80rpx; }
.formula-value { font-size: 24rpx; color: #334155; flex: 1; }

/* 证据要点 */
.evidence-item { display: flex; align-items: flex-start; padding: 16rpx 0; border-bottom: 1rpx solid #f1f5f9; }
.evidence-num {
  width: 44rpx; height: 44rpx; border-radius: 22rpx;
  background: #d1fae5; color: #065f46;
  font-size: 22rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; margin-right: 20rpx;
}
.evidence-text { font-size: 26rpx; color: #334155; line-height: 1.6; flex: 1; }

/* AI 分析折叠 */
.toggle-header { display: flex; align-items: center; justify-content: space-between; }
.toggle-arrow { font-size: 28rpx; color: #94a3b8; }
.explanation-text {
  margin-top: 20rpx; font-size: 26rpx; color: #475569; line-height: 1.8;
  white-space: pre-wrap;
}

/* 图片资源 */
.assets-grid { display: flex; flex-wrap: wrap; gap: 16rpx; margin-top: 20rpx; }
.asset-item { width: calc(50% - 8rpx); box-sizing: border-box; }
.asset-img {
  width: 100%; height: 220rpx; border-radius: 16rpx; display: block;
  background: #f1f5f9;
}
.asset-label { display: block; font-size: 22rpx; color: #64748b; text-align: center; margin-top: 8rpx; }

/* 问诊信息 */
.q-item { display: flex; padding: 16rpx 0; border-bottom: 1rpx solid #f1f5f9; }
.q-label { width: 140rpx; font-size: 26rpx; color: #64748b; font-weight: 600; flex-shrink: 0; }
.q-value { flex: 1; font-size: 26rpx; color: #334155; }

/* ===== 医生确认结果样式 ===== */
.doctor-result-header {
  display: flex; align-items: center; gap: 20rpx;
  background: linear-gradient(135deg, #ecfdf5, #d1fae5);
  border-radius: 24rpx; padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid #6ee7b7;
}
.doctor-result-icon { font-size: 52rpx; flex-shrink: 0; }
.doctor-result-info { flex: 1; }
.doctor-result-title { display: block; font-size: 30rpx; font-weight: 700; color: #065f46; }
.doctor-result-sub { display: block; font-size: 22rpx; color: #047857; margin-top: 4rpx; }

/* 医生确认的标签（更深绿/青色） */
.tag-confirmed.tag-syndrome { background: #059669; color: #ffffff; }
.tag-confirmed.badge-error { background: #fee2e2; color: #ef4444; }

/* 操作栏 */
.action-bar {
  margin: 0 32rpx 24rpx;
  display: flex;
  justify-content: flex-end;
}

.btn-outline-danger {
  background: transparent;
  color: #ef4444;
  border: 2rpx solid #fca5a5;
  border-radius: 12rpx;
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  line-height: 1;
  margin: 0;
  white-space: nowrap;
}
.btn-outline-danger:active {
  background: #fef2f2;
}

/* 医嘱框 */
.note-box {
  background: #fefce8; border: 2rpx solid #fde68a;
  border-radius: 16rpx; padding: 24rpx 28rpx;
  margin-top: 8rpx;
}
.note-text { font-size: 28rpx; color: #78350f; line-height: 1.8; white-space: pre-wrap; }

/* AI 参考分隔线 */
.section-divider {
  display: flex; align-items: center; margin: 16rpx 0;
}
.divider-text {
  font-size: 22rpx; color: #94a3b8; font-weight: 500;
  background: #f1f5f9; border-radius: 20rpx;
  padding: 8rpx 24rpx; margin: 0 auto;
}

/* AI 参考卡片（视觉弱化） */
.card-reference { opacity: 0.75; }
