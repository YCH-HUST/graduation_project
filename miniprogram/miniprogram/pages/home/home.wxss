/* pages/home/home.wxss */
.home-page { padding-bottom: 40rpx; }

/* 个人信息卡片 */
.profile-card {
  background: #ffffff;
  border-radius: 28rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4px 20px rgba(0,0,0,0.08);
}

.profile-bg {
  height: 80rpx;
  background: linear-gradient(135deg, #10b981, #14b8a6);
}

.profile-content {
  display: flex;
  align-items: center;
  padding: 0 32rpx 24rpx;
  margin-top: -40rpx;
}

.avatar-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #10b981, #0d9488);
  border: 6rpx solid #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 16px rgba(16,185,129,0.3);
  flex-shrink: 0;
}

.avatar-text {
  font-size: 44rpx;
  color: #ffffff;
  font-weight: 700;
}

.profile-info {
  flex: 1;
  padding: 30rpx 20rpx 0;
}

.profile-name {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.profile-username {
  display: block;
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}

.edit-btn {
  margin-top: 28rpx;
  padding: 10rpx 24rpx;
  border: 2rpx solid #10b981;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #10b981;
}

.info-row {
  display: flex;
  padding: 0 32rpx 24rpx;
  gap: 16rpx;
}

.info-item {
  flex: 1;
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 16rpx 12rpx;
  text-align: center;
}

.info-label {
  display: block;
  font-size: 20rpx;
  color: #94a3b8;
  margin-bottom: 6rpx;
}

.info-value {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #334155;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 统计卡片 */
.stats-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  flex: 1;
  border-radius: 20rpx;
  padding: 28rpx 16rpx;
  text-align: center;
}

.stat-pending {
  background: linear-gradient(135deg, #fef3c7, #fde68a);
}
.stat-running {
  background: linear-gradient(135deg, #dbeafe, #bfdbfe);
}
.stat-done {
  background: linear-gradient(135deg, #d1fae5, #a7f3d0);
}

.stat-num {
  display: block;
  font-size: 56rpx;
  font-weight: 800;
  color: #0f172a;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #475569;
  margin-top: 8rpx;
}

/* 病例列表 */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.btn-new {
  background: linear-gradient(135deg, #10b981, #14b8a6);
  color: #ffffff;
  font-size: 24rpx;
  border-radius: 20rpx;
  padding: 0 24rpx;
  height: 56rpx;
  line-height: 56rpx;
  border: none;
}
.btn-new::after { border: none; }

.case-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}
.case-item:last-child { border-bottom: none; }

.case-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #d1fae5, #a7f3d0);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.case-icon { font-size: 36rpx; }

.case-info {
  flex: 1;
  padding: 0 20rpx;
}

.case-complaint {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 6rpx;
}

.case-time {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
}

.case-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.arrow {
  font-size: 36rpx;
  color: #cbd5e1;
}

/* 全屏加载 */
.full-loading {
  height: 80vh;
}
.loading-icon { font-size: 64rpx; margin-bottom: 20rpx; }
