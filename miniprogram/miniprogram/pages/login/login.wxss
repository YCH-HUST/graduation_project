/* pages/login/login.wxss */
.login-page {
  min-height: 100vh;
  background: linear-gradient(160deg, #f0fdf4 0%, #ccfbf1 50%, #e0f2fe 100%);
  padding: 80rpx 48rpx 48rpx;
  box-sizing: border-box;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.logo-wrap {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #10b981, #14b8a6);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 12px 32px rgba(16, 185, 129, 0.3);
}

.logo-icon {
  font-size: 64rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: 800;
  color: #064e3b;
  letter-spacing: 2rpx;
}

.app-subtitle {
  font-size: 26rpx;
  color: #6b7280;
  margin-top: 8rpx;
}

/* 标签栏 */
.tab-bar {
  display: flex;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 8rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.tab-item {
  flex: 1;
  text-align: center;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #94a3b8;
  font-weight: 600;
  transition: all 0.2s;
}

.tab-item.active {
  background: linear-gradient(135deg, #10b981, #14b8a6);
  color: #ffffff;
  box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
}

/* 表单卡片 */
.form-card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 40rpx 36rpx;
  box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
}

.error-text {
  font-size: 24rpx;
  color: #ef4444;
  margin-bottom: 20rpx;
  padding: 16rpx 20rpx;
  background: #fee2e2;
  border-radius: 12rpx;
}

.hint-text {
  text-align: center;
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 28rpx;
}
