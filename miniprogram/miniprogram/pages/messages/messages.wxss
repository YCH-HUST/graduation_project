.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f8fafc;
}

.header {
  padding: 30rpx 40rpx;
  background-color: #fff;
  padding-top: env(safe-area-inset-top);
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #0f172a;
}

.list-container {
  flex: 1;
  padding: 20rpx;
  box-sizing: border-box;
}

.loading, .empty {
  text-align: center;
  color: #94a3b8;
  margin-top: 100rpx;
  font-size: 28rpx;
}

.conv-item {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.02);
}

.avatar {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  margin-right: 24rpx;
  background-color: #e2e8f0;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.avatar image {
  width: 48rpx;
  height: 48rpx;
  opacity: 0.6;
}

.badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  background-color: #ef4444;
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
  font-weight: bold;
  border: 4rpx solid #fff;
}

.info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.name {
  font-size: 32rpx;
  font-weight: 500;
  color: #1e293b;
}

.time {
  font-size: 24rpx;
  color: #94a3b8;
}

.bottom {
  display: flex;
  align-items: center;
}

.msg-text {
  font-size: 28rpx;
  color: #64748b;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}
