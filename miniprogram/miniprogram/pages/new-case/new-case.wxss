/* pages/new-case/new-case.wxss */
.new-case-page { padding-bottom: 60rpx; }

/* 步骤头 */
.step-header { margin-bottom: 32rpx; }
.step-title { display: block; font-size: 44rpx; font-weight: 800; color: #0f172a; }
.step-sub { display: block; font-size: 26rpx; color: #94a3b8; margin-top: 6rpx; }
.back-btn { font-size: 28rpx; color: #10b981; margin-bottom: 12rpx; }

/* 科室网格 */
.dept-grid { display: flex; flex-wrap: wrap; gap: 20rpx; }
.dept-card {
  width: calc(50% - 10rpx);
  box-sizing: border-box;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  border: 2rpx solid #e2e8f0;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
  transition: all 0.2s;
}
.dept-card.selected {
  border-color: #10b981;
  background: #f0fdf4;
  box-shadow: 0 4px 16px rgba(16,185,129,0.2);
}
.dept-icon { display: block; font-size: 56rpx; margin-bottom: 12rpx; }
.dept-name { display: block; font-size: 30rpx; font-weight: 700; color: #0f172a; margin-bottom: 6rpx; }
.dept-desc { display: block; font-size: 22rpx; color: #94a3b8; }

/* 医生卡片 */
.doctor-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid #e2e8f0;
  display: flex;
  align-items: center;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}
.doctor-card.selected {
  border-color: #10b981;
  background: #f0fdf4;
}
.doctor-avatar {
  width: 80rpx; height: 80rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #3b82f6, #6366f1);
  color: #fff;
  font-size: 36rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.doctor-info { flex: 1; padding: 0 20rpx; }
.doctor-name { display: block; font-size: 30rpx; font-weight: 700; color: #0f172a; margin-bottom: 10rpx; }
.doctor-tags { display: flex; gap: 12rpx; flex-wrap: wrap; margin-bottom: 8rpx; }
.tag-purple {
  font-size: 20rpx; padding: 4rpx 16rpx; border-radius: 20rpx;
  background: #f3e8ff; color: #7c3aed;
}
.tag-green {
  font-size: 20rpx; padding: 4rpx 16rpx; border-radius: 20rpx;
  background: #dcfce7; color: #15803d;
}
.doctor-hospital { font-size: 22rpx; color: #94a3b8; }
.check-icon { font-size: 36rpx; color: #10b981; font-weight: 700; }

/* 图片上传 */
.image-upload {
  width: 100%; height: 320rpx;
  background: #f8fafc;
  border: 2rpx dashed #cbd5e1;
  border-radius: 20rpx;
  display: flex; align-items: center; justify-content: center;
  overflow: hidden;
  margin: 16rpx 0;
}
.tongue-preview { width: 100%; height: 100%; }
.upload-placeholder { text-align: center; }
.upload-icon { display: block; font-size: 72rpx; margin-bottom: 16rpx; }
.upload-text { font-size: 28rpx; color: #94a3b8; }

/* 标注图 */
.annotated-img { width: 100%; border-radius: 16rpx; margin-top: 16rpx; }

/* 检测详情 */
.detection-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}
.detection-dot { width: 20rpx; height: 20rpx; border-radius: 10rpx; background: #10b981; margin-right: 20rpx; flex-shrink: 0; }
.detection-info { flex: 1; }
.detection-name { display: block; font-size: 28rpx; font-weight: 600; color: #0f172a; }
.detection-id { display: block; font-size: 22rpx; color: #94a3b8; margin-top: 4rpx; }
.conf-badge { padding: 8rpx 20rpx; border-radius: 20rpx; font-size: 24rpx; font-weight: 700; }
.conf-high { background: #dcfce7; color: #15803d; }
.conf-mid { background: #fef9c3; color: #854d0e; }
.conf-low { background: #f1f5f9; color: #64748b; }

/* 状态卡片 */
.status-card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 4px 24px rgba(0,0,0,0.08);
  margin-top: 40rpx;
}
.status-icon { display: block; font-size: 100rpx; margin-bottom: 24rpx; }
.status-title { display: block; font-size: 40rpx; font-weight: 800; color: #0f172a; margin-bottom: 12rpx; }
.status-desc { display: block; font-size: 26rpx; color: #94a3b8; }

.anim-pulse { animation: pulse 1.5s ease-in-out infinite; }
@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.7; transform: scale(0.95); }
}

/* 阶段指示器 */
.stages-row { display: flex; gap: 8rpx; margin-top: 40rpx; }
.stage-item { flex: 1; text-align: center; }
.stage-dot {
  width: 44rpx; height: 44rpx; border-radius: 22rpx;
  background: #e2e8f0; color: #94a3b8;
  font-size: 20rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 8rpx;
}
.stage-active .stage-dot { background: #d1fae5; color: #10b981; }
.stage-done .stage-dot { background: #10b981; color: #ffffff; }
.stage-label { font-size: 18rpx; color: #94a3b8; }
