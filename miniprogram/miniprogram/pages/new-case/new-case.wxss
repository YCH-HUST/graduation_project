/* pages/new-case/new-case.wxss */
.new-case-page { padding-bottom: 60rpx; }

/* 步骤头 */
.step-header { margin-bottom: 32rpx; }
.step-title { display: block; font-size: 44rpx; font-weight: 800; color: #0f172a; }
.step-sub { display: block; font-size: 26rpx; color: #94a3b8; margin-top: 6rpx; }
.back-btn { font-size: 28rpx; color: #10b981; margin-bottom: 12rpx; }

/* 科室网格 */
.dept-grid { display: flex; flex-wrap: wrap; gap: 20rpx; }
.dept-card {
  width: calc(50% - 10rpx);
  box-sizing: border-box;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  border: 2rpx solid #e2e8f0;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
  transition: all 0.2s;
}
.dept-card.selected {
  border-color: #10b981;
  background: #f0fdf4;
  box-shadow: 0 4px 16px rgba(16,185,129,0.2);
}
.dept-icon { display: block; font-size: 56rpx; margin-bottom: 12rpx; }
.dept-name { display: block; font-size: 30rpx; font-weight: 700; color: #0f172a; margin-bottom: 6rpx; }
.dept-desc { display: block; font-size: 22rpx; color: #94a3b8; }

/* 医生卡片 */
.doctor-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid #e2e8f0;
  display: flex;
  align-items: center;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}
.doctor-card.selected {
  border-color: #10b981;
  background: #f0fdf4;
}
.doctor-avatar {
  width: 80rpx; height: 80rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #3b82f6, #6366f1);
  color: #fff;
  font-size: 36rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.doctor-info { flex: 1; padding: 0 20rpx; }
.doctor-name { display: block; font-size: 30rpx; font-weight: 700; color: #0f172a; margin-bottom: 10rpx; }
.doctor-tags { display: flex; gap: 12rpx; flex-wrap: wrap; margin-bottom: 8rpx; }
.tag-purple {
  font-size: 20rpx; padding: 4rpx 16rpx; border-radius: 20rpx;
  background: #f3e8ff; color: #7c3aed;
}
.tag-green {
  font-size: 20rpx; padding: 4rpx 16rpx; border-radius: 20rpx;
  background: #dcfce7; color: #15803d;
}
.doctor-hospital { font-size: 22rpx; color: #94a3b8; }
.check-icon { font-size: 36rpx; color: #10b981; font-weight: 700; }

/* 图片上传 */
.image-upload {
  width: 100%; height: 320rpx;
  background: #f8fafc;
  border: 2rpx dashed #cbd5e1;
  border-radius: 20rpx;
  display: flex; align-items: center; justify-content: center;
  overflow: hidden;
  margin: 16rpx 0;
}
.tongue-preview { width: 100%; height: 100%; }
.upload-placeholder { text-align: center; }
.upload-icon { display: block; font-size: 72rpx; margin-bottom: 16rpx; }
.upload-text { font-size: 28rpx; color: #94a3b8; }

/* 标注图 */
.annotated-img { width: 100%; border-radius: 16rpx; margin-top: 16rpx; }

/* 检测详情 */
.detection-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}
.detection-dot { width: 20rpx; height: 20rpx; border-radius: 10rpx; background: #10b981; margin-right: 20rpx; flex-shrink: 0; }
.detection-info { flex: 1; }
.detection-name { display: block; font-size: 28rpx; font-weight: 600; color: #0f172a; }
.detection-id { display: block; font-size: 22rpx; color: #94a3b8; margin-top: 4rpx; }
.conf-badge { padding: 8rpx 20rpx; border-radius: 20rpx; font-size: 24rpx; font-weight: 700; }
.conf-high { background: #dcfce7; color: #15803d; }
.conf-mid { background: #fef9c3; color: #854d0e; }
.conf-low { background: #f1f5f9; color: #64748b; }

/* 状态卡片 */
.status-card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 4px 24px rgba(0,0,0,0.08);
  margin-top: 40rpx;
}
.status-icon { display: block; font-size: 100rpx; margin-bottom: 24rpx; }
.status-title { display: block; font-size: 40rpx; font-weight: 800; color: #0f172a; margin-bottom: 12rpx; }
.status-desc { display: block; font-size: 26rpx; color: #94a3b8; }

.anim-pulse { animation: pulse 1.5s ease-in-out infinite; }
@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.7; transform: scale(0.95); }
}

/* 阶段指示器 */
.stages-row { display: flex; gap: 8rpx; margin-top: 40rpx; }
.stage-item { flex: 1; text-align: center; }
.stage-dot {
  width: 44rpx; height: 44rpx; border-radius: 22rpx;
  background: #e2e8f0; color: #94a3b8;
  font-size: 20rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 8rpx;
}
.stage-active .stage-dot { background: #d1fae5; color: #10b981; }
.stage-done .stage-dot { background: #10b981; color: #ffffff; }
.stage-label { font-size: 18rpx; color: #94a3b8; }

/* ===== 检测结果页新样式 ===== */

/* 结果摘要 Banner */
.result-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #0f172a, #1e3a5f);
  border-radius: 28rpx;
  padding: 32rpx 36rpx;
  margin-bottom: 24rpx;
}
.result-banner-left { display: flex; align-items: center; gap: 24rpx; }
.result-banner-icon { font-size: 56rpx; }
.result-banner-title { display: block; font-size: 32rpx; font-weight: 800; color: #ffffff; }
.result-banner-sub { display: block; font-size: 22rpx; color: #94a3b8; margin-top: 4rpx; }

/* 置信度圆环显示 */
.result-score-ring {
  width: 100rpx; height: 100rpx;
  border-radius: 50rpx;
  background: rgba(16,185,129,0.2);
  border: 3rpx solid #10b981;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
}
.result-score-num { font-size: 26rpx; font-weight: 800; color: #10b981; line-height: 1.2; }
.result-score-label { font-size: 16rpx; color: #6ee7b7; }

/* 标注图头部 */
.annotated-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 4rpx; }
.annotated-tip { font-size: 22rpx; color: #94a3b8; }

/* 检测特征网格（chip 布局） */
.detection-grid { display: flex; flex-wrap: wrap; gap: 16rpx; margin-top: 16rpx; }
.detection-chip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 20rpx;
  border-radius: 48rpx;
  border: 2rpx solid transparent;
}
/* 高置信 chip（绿色） */
.conf-high-chip { background: #d1fae5; border-color: #6ee7b7; }
.conf-high-chip .chip-name { color: #065f46; font-size: 26rpx; font-weight: 700; }
.conf-high-chip .chip-badge { background: #059669; color: #fff; font-size: 20rpx; font-weight: 700; padding: 4rpx 14rpx; border-radius: 20rpx; }
/* 中置信 chip（黄色） */
.conf-mid-chip { background: #fef9c3; border-color: #fde047; }
.conf-mid-chip .chip-name { color: #713f12; font-size: 26rpx; font-weight: 700; }
.conf-mid-chip .chip-badge { background: #d97706; color: #fff; font-size: 20rpx; font-weight: 700; padding: 4rpx 14rpx; border-radius: 20rpx; }
/* 低置信 chip（灰色） */
.conf-low-chip { background: #f1f5f9; border-color: #e2e8f0; }
.conf-low-chip .chip-name { color: #475569; font-size: 26rpx; font-weight: 700; }
.conf-low-chip .chip-badge { background: #94a3b8; color: #fff; font-size: 20rpx; font-weight: 700; padding: 4rpx 14rpx; border-radius: 20rpx; }

/* 置信图例 */
.conf-legend { display: flex; gap: 24rpx; margin-top: 20rpx; padding-top: 16rpx; border-top: 1rpx solid #f1f5f9; }
.conf-legend-item { display: flex; align-items: center; gap: 8rpx; font-size: 20rpx; color: #64748b; }
.conf-dot { width: 18rpx; height: 18rpx; border-radius: 9rpx; flex-shrink: 0; }
.conf-high-dot { background: #059669; }
.conf-mid-dot { background: #d97706; }
.conf-low-dot { background: #94a3b8; }

/* 温馨提示卡片 */
.tip-card {
  display: flex; align-items: flex-start; gap: 20rpx;
  background: #fffbeb; border: 2rpx solid #fde68a;
  border-radius: 20rpx; padding: 24rpx 28rpx;
  margin-bottom: 32rpx;
}
.tip-icon { font-size: 40rpx; flex-shrink: 0; }
.tip-text { font-size: 24rpx; color: #92400e; line-height: 1.7; flex: 1; }

/* 大提交按钮 */
.btn-submit-lg {
  font-size: 32rpx !important;
  padding: 28rpx 0 !important;
  border-radius: 20rpx !important;
  letter-spacing: 1rpx;
}

/* 处理中状态球 (取代纯 emoji) */
.status-orb {
  width: 140rpx; height: 140rpx; border-radius: 70rpx;
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 32rpx;
}
.orb-processing {
  background: linear-gradient(135deg, #d1fae5, #6ee7b7);
  animation: orbPulse 2s ease-in-out infinite;
  box-shadow: 0 0 0 0 rgba(16,185,129,0.5);
}
.orb-success { background: linear-gradient(135deg, #d1fae5, #6ee7b7); }
.status-orb-icon { font-size: 72rpx; }
@keyframes orbPulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(16,185,129,0.4); }
  50% { box-shadow: 0 0 0 24rpx rgba(16,185,129,0); }
}

/* 进度百分比文字 */
.progress-pct { font-size: 28rpx; color: #10b981; font-weight: 700; }

/* progress-full 覆盖到 100% */
.progress-full { width: 100% !important; background: #10b981; }
