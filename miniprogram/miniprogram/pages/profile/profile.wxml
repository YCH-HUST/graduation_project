<view class="page-container" wx:if="{{!isLoading}}">

  <!-- 头部 -->
  <view class="profile-header">
    <view class="avatar-big"><text class="avatar-big-text">{{userInitial}}</text></view>
    <text class="username-text">@{{username}}</text>
  </view>

  <!-- 编辑表单 -->
  <view class="card">
    <text class="card-title" style="margin-bottom:28rpx">编辑个人信息</text>

    <view class="form-group">
      <text class="form-label">姓名</text>
      <input
        class="form-input"
        placeholder="请输入姓名"
        value="{{formData.full_name}}"
        bindinput="onInput"
        data-field="full_name"
      />
    </view>

    <view class="form-group">
      <text class="form-label">邮箱</text>
      <input
        class="form-input"
        type="email"
        placeholder="请输入邮箱"
        value="{{formData.email}}"
        bindinput="onInput"
        data-field="email"
      />
    </view>

    <view class="form-group">
      <text class="form-label">性别</text>
      <view class="gender-row">
        <view
          class="gender-btn {{formData.gender === 'male' ? 'active' : ''}}"
          bindtap="onGenderSelect"
          data-gender="male"
        >男</view>
        <view
          class="gender-btn {{formData.gender === 'female' ? 'active' : ''}}"
          bindtap="onGenderSelect"
          data-gender="female"
        >女</view>
      </view>
    </view>

    <view class="form-group">
      <text class="form-label">年龄</text>
      <input
        class="form-input"
        type="number"
        placeholder="请输入年龄"
        value="{{formData.age}}"
        bindinput="onInput"
        data-field="age"
      />
    </view>

    <view style="display:flex;gap:20rpx;margin-top:16rpx">
      <button
        class="save-btn {{isSaving ? 'btn-disabled' : ''}}"
        disabled="{{isSaving}}"
        bindtap="onSave"
        style="flex:1"
      >
        {{isSaving ? '保存中...' : '保存修改'}}
      </button>
      <button class="logout-btn" bindtap="onLogout" style="flex:1">退出登录</button>
    </view>
  </view>

  <!-- 修改密码 -->
  <view class="card">
    <text class="card-title" style="margin-bottom:28rpx">🔒 修改密码</text>

    <view class="form-group">
      <text class="form-label">原密码</text>
      <input class="form-input" password placeholder="请输入原密码" value="{{pwForm.old_password}}" bindinput="onPwInput" data-field="old_password" />
    </view>
    <view class="form-group">
      <text class="form-label">新密码</text>
      <input class="form-input" password placeholder="至少 6 位" value="{{pwForm.new_password}}" bindinput="onPwInput" data-field="new_password" />
    </view>
    <view class="form-group">
      <text class="form-label">确认新密码</text>
      <input class="form-input" password placeholder="再次输入新密码" value="{{pwForm.confirm_password}}" bindinput="onPwInput" data-field="confirm_password" />
    </view>

    <button class="save-btn {{isChangingPw ? 'btn-disabled' : ''}}" disabled="{{isChangingPw}}" bindtap="onChangePassword">
      {{isChangingPw ? '提交中...' : '确认修改密码'}}
    </button>
  </view>

</view>

<view class="loading-wrap full-loading" wx:if="{{isLoading}}">
  <text style="font-size:72rpx">⏳</text>
  <text class="loading-text">加载中...</text>
</view>
